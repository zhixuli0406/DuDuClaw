#!/usr/bin/env bash
# Phase 1: Bash command blacklist (PreToolUse — Bash)
#
# CONFLICT NOTE [P1->P3]:
#   Phase 3 replaces this script with bash-gate.sh.
#   All patterns in DANGEROUS_PATTERNS are "Layer 1" and must be
#   migrated verbatim into bash-gate.sh. Do NOT add a second
#   PreToolUse Bash matcher — replace this entry instead.
#
# Exit behavior:
#   exit 0 + JSON with permissionDecision:"deny"  → block the command
#   exit 0 + no JSON                               → allow the command
#   exit 2 + stderr                                → block (fallback)

set -euo pipefail

INPUT="$(cat)"

COMMAND="$(printf '%s' "$INPUT" | jq -r '.tool_input.command // empty')"

# No command to check — allow
if [[ -z "$COMMAND" ]]; then
  exit 0
fi

# ---------------------------------------------------------------------------
# Layer 1: Deterministic blacklist (<50ms)
#   Each entry is an extended-regex pattern checked case-insensitively.
#   Keep patterns ordered by severity.
# ---------------------------------------------------------------------------
DANGEROUS_PATTERNS=(
  # Filesystem destruction
  'rm\s+-[a-zA-Z]*r[a-zA-Z]*f[a-zA-Z]*\s+/'
  'rm\s+-[a-zA-Z]*f[a-zA-Z]*r[a-zA-Z]*\s+/'
  'rm\s+-rf\s+\*'
  'rm\s+-rf\s+\.'

  # Disk destruction
  '>\s*/dev/sd[a-z]'
  '>\s*/dev/nvme'
  'mkfs\.'
  'dd\s+if=.*of=/dev/'

  # Fork bomb
  ':\(\)\{.*\|.*&\}\s*;'

  # Remote code execution
  'curl\s+.*\|\s*(ba)?sh'
  'wget\s+.*\|\s*(ba)?sh'
  'curl\s+.*\|\s*sudo'
  'wget\s+.*\|\s*sudo'

  # SQL destruction (covers piped or inline invocations)
  'DROP\s+(TABLE|DATABASE|SCHEMA)'
  'DELETE\s+FROM\s+.*WHERE\s+1'
  'TRUNCATE\s+TABLE'

  # Dangerous permission changes
  'chmod\s+777'
  'chmod\s+-R\s+777'
  'chmod\s+a\+rwx'

  # Credential / key exfiltration via network
  'curl\s+.*secret\.key'
  'curl\s+.*\.credentials'
  'wget\s+.*secret\.key'

  # Eval / exec injection (shell-level)
  'eval\s+"\$\('
  'bash\s+-c\s+.*\$\{.*\}'

  # System-critical overwrite
  '>\s*/etc/passwd'
  '>\s*/etc/shadow'
)

for pattern in "${DANGEROUS_PATTERNS[@]}"; do
  if printf '%s' "$COMMAND" | grep -iqE -- "$pattern"; then
    # Deny with structured JSON
    jq -n --arg pattern "$pattern" --arg cmd "$COMMAND" '{
      "hookSpecificOutput": {
        "hookEventName": "PreToolUse",
        "permissionDecision": "deny",
        "permissionDecisionReason": ("SECURITY BLOCK: Command matches dangerous pattern [" + $pattern + "]: " + $cmd)
      }
    }'
    exit 0
  fi
done

# All checks passed — allow
exit 0
