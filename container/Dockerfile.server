# DuDuClaw Server - Multi-stage build

# Stage 1: Frontend build
FROM node:22-slim AS frontend-builder
WORKDIR /build/web
COPY web/package.json web/package-lock.json ./
RUN npm ci --legacy-peer-deps
COPY web/ ./
RUN npm run build

# Stage 2: Rust compilation
FROM rust:slim AS rust-builder
WORKDIR /build
RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev && \
    rm -rf /var/lib/apt/lists/*
COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/
# Copy pre-built frontend assets for dashboard embedding
COPY --from=frontend-builder /build/crates/duduclaw-dashboard/dist/ crates/duduclaw-dashboard/dist/
# Build release binary
RUN cargo build --release -p duduclaw-cli

# Stage 3: Production image
FROM python:3.12-slim

# Create non-root user
RUN groupadd -r duduclaw && useradd -r -g duduclaw -u 1000 duduclaw

# Copy built Rust binary
COPY --from=rust-builder /build/target/release/duduclaw /usr/local/bin/

# Copy Python extensions (pure Python parts)
COPY python/ /opt/duduclaw/python/
ENV PYTHONPATH=/opt/duduclaw

# Install Python dependencies
RUN pip install --no-cache-dir anthropic

# Install Docker CLI and curl for healthcheck
RUN apt-get update && apt-get install -y --no-install-recommends \
    docker.io ca-certificates curl && \
    rm -rf /var/lib/apt/lists/*

# Copy entrypoint
COPY container/server-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER duduclaw
WORKDIR /home/duduclaw
VOLUME /home/duduclaw/.duduclaw
EXPOSE 18789

ENTRYPOINT ["/entrypoint.sh"]
CMD ["duduclaw", "run", "--yes"]
