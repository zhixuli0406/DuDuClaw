# DuDuClaw Server - Multi-stage build

# Stage 1: Frontend build
FROM node:22-slim AS frontend-builder
WORKDIR /build/web
COPY web/package.json web/package-lock.json ./
RUN npm ci --legacy-peer-deps
COPY web/ ./
RUN npm run build

# Stage 2: Rust compilation
FROM rust:slim AS rust-builder
WORKDIR /build
RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev && \
    rm -rf /var/lib/apt/lists/*
COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/
# duduclaw-memory + duduclaw-cli use include_str! against templates/wiki/*.
# Missing this dir → "No such file or directory" at compile time.
COPY templates/ templates/
# Copy pre-built frontend assets for dashboard embedding
COPY --from=frontend-builder /build/crates/duduclaw-dashboard/dist/ crates/duduclaw-dashboard/dist/
# Build release binary with dashboard only (desktop feature excluded —
# Computer Use / screen capture lives in the dedicated Dockerfile.computer-use
# image; pulling xcap/enigo here would drag in wayland/pipewire/gbm on Linux).
RUN cargo build --release \
    --no-default-features \
    --features duduclaw-gateway/dashboard \
    -p duduclaw-cli -p duduclaw-gateway

# Stage 3: Production image
FROM python:3.12-slim

# Create non-root user
RUN groupadd -r duduclaw && useradd -r -g duduclaw -u 1000 duduclaw

# Copy built Rust binary
COPY --from=rust-builder /build/target/release/duduclaw /usr/local/bin/

# Copy Python extensions (pure Python parts)
COPY python/ /opt/duduclaw/python/
ENV PYTHONPATH=/opt/duduclaw

# Install Python dependencies
RUN pip install --no-cache-dir anthropic==0.50.0

# Install Docker CLI, Node.js 22, multi-runtime AI CLIs (Claude/Codex/Gemini), and curl for healthcheck
RUN apt-get update && apt-get install -y --no-install-recommends \
    docker.io ca-certificates curl gnupg && \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    npm install -g \
        @anthropic-ai/claude-code \
        @openai/codex \
        @google/gemini-cli && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Antigravity CLI (`agy`) — Google's official installer (the 2026-06-18
# Gemini-CLI successor). Bundled as a first-class runtime alongside
# claude/codex so the Antigravity backend works out of the box. The installer
# supports linux amd64/arm64 (glibc); it drops the binary in $HOME/.local/bin,
# which we relocate to /usr/local/bin so every user (incl. `duduclaw`) resolves
# it on PATH — matching `duduclaw-core::which_agy`.
RUN curl -fsSL https://antigravity.google/cli/install.sh | bash && \
    install -m 0755 "$HOME/.local/bin/agy" /usr/local/bin/agy && \
    agy --version

# Grok CLI (`grok`, aka "Grok Build") — xAI's official installer. Bundled as a
# first-class runtime alongside claude/codex/gemini/agy so the Grok backend
# works out of the box. There is no npm/apt package (see
# crates/duduclaw-gateway/src/runtime/grok.rs header for the verification
# notes); the official install method is this curl|bash script. It resolves
# the latest stable release, downloads the linux amd64/arm64 (glibc) binary,
# self-tests it (`--version`) before linking, and drops the canonical symlink
# at $HOME/.grok/bin/grok — which we resolve+relocate to /usr/local/bin so
# every user (incl. `duduclaw`) finds it on PATH, matching
# `duduclaw-core::which_grok`. `install` dereferences the symlink so the real
# binary (not a dangling link into $HOME/.grok/downloads) lands in
# /usr/local/bin. NOTE: `XAI_API_KEY` auth is NOT baked in here — it is
# supplied at container **runtime** via env / agent.toml, same as the other
# CLIs (ANTHROPIC_API_KEY / OPENAI_API_KEY / GEMINI_API_KEY).
RUN curl -fsSL https://x.ai/cli/install.sh | bash && \
    install -m 0755 "$HOME/.grok/bin/grok" /usr/local/bin/grok && \
    grok --version

# Copy entrypoint
COPY container/server-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

RUN mkdir -p \
        /home/duduclaw/.duduclaw \
        /home/duduclaw/.claude \
        /home/duduclaw/.codex \
        /home/duduclaw/.gemini \
        /home/duduclaw/.grok && \
    chown -R duduclaw:duduclaw /home/duduclaw

USER duduclaw
WORKDIR /home/duduclaw
VOLUME /home/duduclaw/.duduclaw
VOLUME /home/duduclaw/.claude
VOLUME /home/duduclaw/.codex
VOLUME /home/duduclaw/.gemini
VOLUME /home/duduclaw/.grok
EXPOSE 18789

ENTRYPOINT ["/entrypoint.sh"]
CMD ["duduclaw", "run", "--yes"]
